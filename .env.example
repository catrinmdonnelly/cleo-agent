# Cleo — environment variables
# Copy to .env for local runs, or add as GitHub Actions secrets for the scheduled run.

# REQUIRED
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# RECOMMENDED
BUSINESS_NAME=Your Business Name
ANTHROPIC_MODEL=claude-sonnet-4-6

# Timezone for the "today" date in the brief and the schedule check.
# Any IANA timezone, e.g. Europe/London, America/New_York, Australia/Sydney.
AGENT_TIMEZONE=Europe/London

# OPTIONAL — failure email alerts
# If you set FAILURE_EMAIL_TO and FAILURE_EMAIL_SMTP_PASS, Cleo will email you
# when a run fails. Defaults assume Gmail with an app password.
FAILURE_EMAIL_TO=
FAILURE_EMAIL_FROM=
FAILURE_EMAIL_SMTP_HOST=smtp.gmail.com
FAILURE_EMAIL_SMTP_PASS=
